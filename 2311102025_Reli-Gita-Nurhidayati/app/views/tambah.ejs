<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Tambah Mahasiswa</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <style>
        body {
            background: #f0f4f8;
        }

        .card {
            border: none;
            border-radius: 12px;
            box-shadow: 0 2px 12px rgba(0, 0, 0, .08);
        }

        .watermark {
            position: fixed;
            bottom: 10px;
            right: 14px;
            font-size: 11px;
            color: rgba(0, 0, 0, .2);
            pointer-events: none;
        }
    </style>
</head>

<body>

    <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/"><i class="fas fa-graduation-cap me-2"></i>CRUD Mahasiswa</a>
            <div class="collapse navbar-collapse">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="/"><i class="fas fa-table me-1"></i>Data</a></li>
                    <li class="nav-item"><a class="nav-link" href="/tambah"><i class="fas fa-plus me-1"></i>Tambah</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        <div class="row justify-content-center">
            <div class="col-md-7">
                <div class="card p-4">
                    <h5 class="fw-bold text-primary mb-3"><i class="fas fa-user-plus me-2"></i>Tambah Mahasiswa</h5>
                    <form id="formTambah" action="/tambah" method="POST" novalidate>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">NIM</label>
                            <input type="text" name="nim" class="form-control" placeholder="Contoh: 2311102025"
                                required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Nama Lengkap</label>
                            <input type="text" name="nama" class="form-control" placeholder="Nama lengkap" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Jurusan</label>
                            <select name="jurusan" class="form-select" required>
                                <option value="">-- Pilih Jurusan --</option>
                                <option>Informatika</option>
                                <option>Sistem Informasi</option>
                                <option>Teknik Elektro</option>
                                <option>Teknik Industri</option>
                                <option>Manajemen</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Angkatan</label>
                            <input type="number" name="angkatan" class="form-control" placeholder="2023" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">IPK</label>
                            <input type="number" name="ipk" step="0.01" min="0" max="4" class="form-control"
                                placeholder="0.00 - 4.00" required />
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary"><i
                                    class="fas fa-save me-1"></i>Simpan</button>
                            <a href="/" class="btn btn-outline-secondary"><i
                                    class="fas fa-arrow-left me-1"></i>Kembali</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <div class="watermark">2311102025 | Reli Gita Nurhidayati</div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.20.0/dist/jquery.validate.min.js"></script>
    <script>
        $(function () {
            $('#formTambah').validate({
                rules: {
                    nim: { required: true, minlength: 5 },
                    nama: { required: true },
                    jurusan: { required: true },
                    angkatan: { required: true, digits: true },
                    ipk: { required: true, min: 0, max: 4 }
                },
                messages: {
                    nim: { required: 'NIM wajib diisi', minlength: 'Min 5 karakter' },
                    nama: { required: 'Nama wajib diisi' },
                    jurusan: { required: 'Pilih jurusan' },
                    angkatan: { required: 'Angkatan wajib diisi' },
                    ipk: { required: 'IPK wajib diisi' }
                },
                errorClass: 'is-invalid',
                validClass: 'is-valid',
                errorElement: 'div',
                errorPlacement: function (e, el) { e.addClass('invalid-feedback'); el.after(e); }
            });
        });
    </script>
</body>

</html>