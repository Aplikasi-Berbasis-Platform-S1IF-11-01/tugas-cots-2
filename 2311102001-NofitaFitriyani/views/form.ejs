<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Form Antrian POSBINDU</title>
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet"
  />
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark">
    <div class="container">
      <a class="navbar-brand d-flex align-item-center gap-2" href="/">
        <img src="/images/logo.png" alt="Logo POSBINDU" class="logo-posbindu" />
        <span>POSBINDU</span>
    </a>
      <div class="d-flex gap-2">
        <a href="/" class="btn btn-outline-light btn-sm">Home</a>
        <a href="/form" class="btn btn-outline-light btn-sm">Input Antrian</a>
        <a href="/data" class="btn btn-outline-light btn-sm">Data Antrian</a>
      </div>
    </div>
  </nav>

  <div class="container mt-5">
    <div class="card">
      <div class="card-header bg-success text-white">
        Form Input Antrian POSBINDU
      </div>
      <div class="card-body">
        <form id="formAntrian">
          <div class="mb-3">
            <label for="nama" class="form-label">Nama Lansia</label>
            <input type="text" class="form-control" id="nama" name="nama" required />
          </div>

          <div class="mb-3">
            <label for="umur" class="form-label">Umur</label>
            <input type="number" class="form-control" id="umur" name="umur" required />
          </div>

          <div class="mb-3">
            <label for="keluhan" class="form-label">Keluhan / Keperluan</label>
            <textarea class="form-control" id="keluhan" name="keluhan" rows="3" required></textarea>
          </div>

          <button type="submit" class="btn btn-success">Simpan Antrian</button>
          <a href="/data" class="btn btn-secondary">Lihat Data</a>
        </form>

        <div id="pesanForm" class="mt-3"></div>
      </div>
    </div>
  </div>

  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
  <script src="/script.js"></script>
</body>
</html>