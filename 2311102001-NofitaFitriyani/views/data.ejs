<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Data Antrian POSBINDU</title>
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet"
  />
  <link
    href="https://cdn.datatables.net/1.13.8/css/jquery.dataTables.min.css"
    rel="stylesheet"
  />
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark">
    <div class="container">
      <a class="navbar-brand d-flex align-items-center gap-2" href="/">
        <img src="/images/logo.png" alt="Logo POSBINDU" class="logo-posbindu" />
        <span>POSBINDU</span>
    </a>
      <div class="d-flex gap-2">
        <a href="/" class="btn btn-outline-light btn-sm">Home</a>
        <a href="/form" class="btn btn-outline-light btn-sm">Input Antrian</a>
        <a href="/data" class="btn btn-outline-light btn-sm">Data Antrian</a>
      </div>
    </div>
  </nav>

  <div class="container mt-4">
    <div class="card">
      <div class="card-header bg-success text-white">
        Tabel Data Antrian POSBINDU
      </div>
      <div class="card-body">
        <table id="tabelAntrian" class="table table-bordered table-striped" style="width: 100%;">
          <thead>
            <tr>
              <th>ID</th>
              <th>No. Antrian</th>
              <th>Nama Lansia</th>
              <th>Umur</th>
              <th>Keluhan</th>
              <th>Aksi</th>
            </tr>
          </thead>
        </table>
      </div>
    </div>
  </div>

  <div class="modal fade" id="editModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header bg-warning">
          <h5 class="modal-title">Edit Data Antrian</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <input type="hidden" id="editId" />

          <div class="mb-3">
            <label for="editNama" class="form-label">Nama Lansia</label>
            <input type="text" class="form-control" id="editNama" />
          </div>

          <div class="mb-3">
            <label for="editUmur" class="form-label">Umur</label>
            <input type="number" class="form-control" id="editUmur" />
          </div>

          <div class="mb-3">
            <label for="editKeluhan" class="form-label">Keluhan / Keperluan</label>
            <textarea class="form-control" id="editKeluhan" rows="3"></textarea>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-primary" id="btnUpdate">Update</button>
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
        </div>
      </div>
    </div>
  </div>

  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
  <script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/script.js"></script>
</body>
</html>