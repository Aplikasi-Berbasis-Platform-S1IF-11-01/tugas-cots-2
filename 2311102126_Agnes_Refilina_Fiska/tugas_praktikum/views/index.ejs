<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard Mahasiswa - Modern Portal</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        :root {
            --primary-gradient: linear-gradient(135deg, #4361ee 0%, #3f37c9 100%);
            --bg-light: #f1f4f9;
        }

        body { 
            background-color: var(--bg-light); 
            font-family: 'Inter', sans-serif;
            color: #2d3748;
            min-height: 100vh;
        }

        .circle-deco {
            position: fixed;
            z-index: -1;
            border-radius: 50%;
            background: linear-gradient(135deg, rgba(67, 97, 238, 0.08) 0%, rgba(63, 55, 201, 0.04) 100%);
        }

        .header-section {
            padding: 60px 0 40px 0;
            text-align: center;
        }

        .header-section h1 {
            font-weight: 700;
            color: #1a202c;
            letter-spacing: -1px;
        }

        .glass-card {
            background: white;
            border-radius: 24px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.03);
            padding: 35px;
            border: 1px solid rgba(255, 255, 255, 0.7);
            margin-bottom: 50px;
        }

        .table thead th {
            background-color: transparent;
            color: #718096;
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 0.5px;
            border-bottom: 2px solid #edf2f7;
            padding: 15px;
        }

        .table tbody td {
            padding: 18px 15px;
            vertical-align: middle;
            border-bottom: 1px solid #f7fafc;
            font-size: 0.95rem;
        }

        .table tbody tr:hover {
            background-color: #f8faff;
        }

        .avatar-circle {
            width: 40px;
            height: 40px;
            background: var(--primary-gradient);
            color: white;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
            font-size: 1rem;
            box-shadow: 0 4px 10px rgba(67, 97, 238, 0.2);
        }

        .badge-prodi {
            background: #ebf4ff;
            color: #4361ee;
            padding: 6px 14px;
            border-radius: 10px;
            font-weight: 600;
            font-size: 0.8rem;
            display: inline-block;
        }

        .btn-add {
            background: var(--primary-gradient);
            border: none;
            border-radius: 14px;
            padding: 12px 25px;
            font-weight: 600;
            color: white;
            box-shadow: 0 10px 20px rgba(67, 97, 238, 0.2);
            transition: 0.3s;
        }

        .btn-add:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 25px rgba(67, 97, 238, 0.3);
            color: white;
        }

        .btn-edit {
            width: 38px;
            height: 38px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 12px;
            background: #eef2ff;
            color: #4361ee;
            border: none;
            margin-right: 5px;
            transition: 0.3s;
        }

        .btn-edit:hover { background: #4361ee; color: white; }

        .btn-delete {
            width: 38px;
            height: 38px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 12px;
            background: #fff5f5;
            color: #f56565;
            text-decoration: none;
            transition: 0.3s;
        }

        .btn-delete:hover { background: #feb2b2; color: #c53030; }

        .dataTables_filter input {
            border-radius: 12px !important;
            border: 1.5px solid #e2e8f0 !important;
            padding: 8px 15px !important;
            background: #f8fafc !important;
        }
    </style>
</head>
<body>

    <div class="circle-deco" style="width: 400px; height: 400px; top: -100px; left: -100px;"></div>
    <div class="circle-deco" style="width: 300px; height: 300px; bottom: 50px; right: -50px;"></div>

    <div class="container">
        <header class="header-section">
            <div class="bg-primary text-white rounded-3 d-inline-flex align-items-center justify-content-center mb-3" style="width: 50px; height: 50px;">
                <i class="fas fa-database fa-lg"></i>
            </div>
            <h1>Manajemen Praktikum</h1>
            <p class="text-muted">Daftar mahasiswa yang terdaftar dalam sistem.</p>
        </header>

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h5 class="fw-bold mb-0"><i class="fas fa-list me-2 text-primary"></i>Data Mahasiswa</h5>
            <a href="/tambah" class="btn btn-add">
                <i class="fas fa-plus-circle me-2"></i> Tambah Mahasiswa
            </a>
        </div>

        <div class="glass-card">
            <div class="table-responsive">
                <table id="tabelMhs" class="table w-100">
                    <thead>
                        <tr>
                            <th>Mahasiswa</th>
                            <th>NIM</th>
                            <th>Program Studi</th>
                            <th class="text-center">Aksi</th>
                        </tr>
                    </thead>
                </table>
            </div>
        </div>
        <p class="text-center text-muted small pb-4">&copy; 2026 Praktikum Web Development_2311102126_Agnes</p>
    </div>

    <div class="modal fade" id="editModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="border-radius: 20px; border: none;">
                <div class="modal-header border-0 pt-4 px-4">
                    <h5 class="fw-bold">Edit Data Mahasiswa</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form action="/update" method="POST">
                    <div class="modal-body p-4">
                        <input type="hidden" name="id" id="edit-id">
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Nama Lengkap</label>
                            <input type="text" name="nama" id="edit-nama" class="form-control" required style="border-radius: 10px;">
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold">NIM</label>
                            <input type="text" name="nim" id="edit-nim" class="form-control" required style="border-radius: 10px;">
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Program Studi</label>
                            <select name="prodi" id="edit-prodi" class="form-select" required style="border-radius: 10px;">
                                 <option value="" disabled selected>Pilih Program Studi</option>
                                 <option value="Teknik Informatika">Teknik Informatika</option>
                                 <option value="Sistem Informasi">Sistem Informasi</option>
                                 <option value="Teknik Komputer">Teknik Komputer</option>
                                 <option value="Teknik Elektro">Teknik Elektro</option>
                                 <option value="Teknik Industri">Teknik Industri</option>
                                 <option value="Sains Data">Sains Data</option>
                            </select>
                        </div>
                    </div>
                    <div class="modal-footer border-0 pb-4 px-4">
                        <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Batal</button>
                        <button type="submit" class="btn btn-primary rounded-pill px-4 shadow">Simpan Perubahan</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    
    <script>
        $(document).ready(function() {
            $('#tabelMhs').DataTable({
                ajax: '/api/mahasiswa',
                language: {
                    search: "_INPUT_",
                    searchPlaceholder: "Cari mahasiswa...",
                    lengthMenu: "Tampilkan _MENU_",
                },
                columns: [
                    { data: 'nama', render: function(data) {
                        return `<div class="d-flex align-items-center">
                                    <div class="avatar-circle me-3">${data.charAt(0)}</div>
                                    <span class="fw-semibold text-dark">${data}</span>
                                </div>`;
                    }},
                    { data: 'nim', render: function(data) {
                        return `<span class="text-muted">${data}</span>`;
                    }},
                    { data: 'prodi', render: function(data) {
                        return `<span class="badge-prodi">${data}</span>`;
                    }},
                    { 
                        data: null, 
                        className: 'text-center',
                        render: function(data) {
                            return `
                                <button class="btn-edit" onclick='openEditModal(${JSON.stringify(data)})'>
                                    <i class="fas fa-edit"></i>
                                </button>
                                <a href="/hapus/${data.id}" class="btn-delete" onclick="return confirm('Yakin hapus data ini?')">
                                    <i class="fas fa-trash-alt"></i>
                                </a>`;
                        }
                    }
                ]
            });
        });

        function openEditModal(data) {
            $('#edit-id').val(data.id);
            $('#edit-nama').val(data.nama);
            $('#edit-nim').val(data.nim);
            $('#edit-prodi').val(data.prodi);
            var myModal = new bootstrap.Modal(document.getElementById('editModal'));
            myModal.show();
        }
    </script>
</body>
</html>