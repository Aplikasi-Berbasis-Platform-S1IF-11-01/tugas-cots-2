<%
  locals.activePage = 'detail';
  const ipkClass = mahasiswa.ipk >= 3.5 ? 'success' : mahasiswa.ipk >= 3.0 ? 'primary' : mahasiswa.ipk >= 2.0 ? 'warning' : 'danger';
  const ipkLabel = mahasiswa.ipk >= 3.5 ? 'Cumlaude' : mahasiswa.ipk >= 3.0 ? 'Sangat Memuaskan' : mahasiswa.ipk >= 2.5 ? 'Memuaskan' : mahasiswa.ipk >= 2.0 ? 'Cukup' : 'Kurang';
%>
<%- include('header') %>

<!-- Breadcrumb -->
<nav class="mb-4" aria-label="breadcrumb">
  <ol class="breadcrumb breadcrumb-custom">
    <li class="breadcrumb-item"><a href="/"><i class="bi bi-house-fill"></i> Dashboard</a></li>
    <li class="breadcrumb-item active">Detail Mahasiswa</li>
  </ol>
</nav>

<div class="row g-4">
  <!-- Profile Card -->
  <div class="col-lg-4">
    <div class="card-custom h-100">
      <div class="card-custom-body text-center py-4">
        <div class="avatar-lg mx-auto mb-3">
          <%= mahasiswa.nama.split(' ').map(w => w[0]).slice(0,2).join('').toUpperCase() %>
        </div>
        <h4 class="fw-700 mb-1"><%= mahasiswa.nama %></h4>
        <p class="text-muted mb-3"><%= mahasiswa.nim %></p>
        <span class="badge-status status-<%= mahasiswa.status.toLowerCase().replace(' ','') %> fs-6 mb-3">
          <%= mahasiswa.status %>
        </span>
        <div class="divider"></div>
        <div class="detail-stat-grid mt-3">
          <div class="detail-stat">
            <div class="detail-stat-value text-<%= ipkClass %>"><%= mahasiswa.ipk.toFixed(2) %></div>
            <div class="detail-stat-label">IPK</div>
          </div>
          <div class="detail-stat">
            <div class="detail-stat-value"><%= mahasiswa.semester %></div>
            <div class="detail-stat-label">Semester</div>
          </div>
        </div>
        <div class="mt-3">
          <small class="badge bg-<%= ipkClass %> bg-opacity-10 text-<%= ipkClass %> px-3 py-2 rounded-pill"><%= ipkLabel %></small>
        </div>
      </div>
    </div>
  </div>

  <!-- Info Card -->
  <div class="col-lg-8">
    <div class="card-custom mb-4">
      <div class="card-custom-header">
        <h5 class="card-custom-title"><i class="bi bi-info-circle-fill me-2"></i>Informasi Akademik</h5>
      </div>
      <div class="card-custom-body">
        <div class="detail-info-list">
          <div class="detail-info-item">
            <div class="detail-info-icon bg-primary-soft text-primary"><i class="bi bi-hash"></i></div>
            <div>
              <div class="detail-info-label">Nomor Induk Mahasiswa</div>
              <div class="detail-info-value mono"><%= mahasiswa.nim %></div>
            </div>
          </div>
          <div class="detail-info-item">
            <div class="detail-info-icon bg-success-soft text-success"><i class="bi bi-person-fill"></i></div>
            <div>
              <div class="detail-info-label">Nama Lengkap</div>
              <div class="detail-info-value"><%= mahasiswa.nama %></div>
            </div>
          </div>
          <div class="detail-info-item">
            <div class="detail-info-icon bg-warning-soft text-warning"><i class="bi bi-building-fill"></i></div>
            <div>
              <div class="detail-info-label">Jurusan / Prodi</div>
              <div class="detail-info-value"><%= mahasiswa.jurusan %></div>
            </div>
          </div>
          <div class="detail-info-item">
            <div class="detail-info-icon bg-info-soft text-info"><i class="bi bi-envelope-fill"></i></div>
            <div>
              <div class="detail-info-label">Email</div>
              <div class="detail-info-value"><a href="mailto:<%= mahasiswa.email %>"><%= mahasiswa.email %></a></div>
            </div>
          </div>
          <div class="detail-info-item">
            <div class="detail-info-icon bg-secondary-soft text-secondary"><i class="bi bi-calendar-check-fill"></i></div>
            <div>
              <div class="detail-info-label">Tanggal Daftar</div>
              <div class="detail-info-value"><%= new Date(mahasiswa.createdAt).toLocaleDateString('id-ID', {day:'numeric', month:'long', year:'numeric'}) %></div>
            </div>
          </div>
        </div>

        <!-- IPK Progress -->
        <div class="mt-4 p-3 bg-light rounded-3">
          <div class="d-flex justify-content-between mb-2">
            <span class="fw-600 text-sm">Indeks Prestasi Kumulatif</span>
            <span class="fw-700 text-<%= ipkClass %>"><%= mahasiswa.ipk.toFixed(2) %> / 4.00</span>
          </div>
          <div class="progress" style="height: 10px; border-radius: 5px;">
            <div class="progress-bar bg-<%= ipkClass %>" style="width: <%= (mahasiswa.ipk / 4) * 100 %>%; border-radius: 5px;"></div>
          </div>
          <div class="d-flex justify-content-between mt-1">
            <small class="text-muted">0.00</small>
            <small class="text-muted">2.00</small>
            <small class="text-muted">3.00</small>
            <small class="text-muted">4.00</small>
          </div>
        </div>
      </div>
    </div>

    <!-- Actions -->
    <div class="d-flex gap-2 justify-content-end flex-wrap">
      <a href="/" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i> Kembali
      </a>
      <a href="/edit/<%= mahasiswa.id %>" class="btn btn-warning text-white">
        <i class="bi bi-pencil-fill me-1"></i> Edit Data
      </a>
      <button class="btn btn-danger" onclick="hapusMahasiswa('<%= mahasiswa.id %>', '<%= mahasiswa.nama %>')">
        <i class="bi bi-trash3-fill me-1"></i> Hapus
      </button>
    </div>
  </div>
</div>

<!-- JSON Preview (bonus) -->
<div class="card-custom mt-4">
  <div class="card-custom-header">
    <h5 class="card-custom-title"><i class="bi bi-braces me-2"></i>JSON Response Preview</h5>
    <button class="btn btn-sm btn-outline-secondary" onclick="toggleJson()">
      <i class="bi bi-eye" id="jsonToggleIcon"></i> <span id="jsonToggleText">Tampilkan</span>
    </button>
  </div>
  <div class="card-custom-body" id="jsonPreview" style="display:none;">
    <pre class="json-preview"><code id="jsonContent"></code></pre>
  </div>
</div>

<script>
const mahasiswaData = <%- JSON.stringify(mahasiswa) %>;
let jsonVisible = false;

function toggleJson() {
  jsonVisible = !jsonVisible;
  if (jsonVisible) {
    $('#jsonContent').text(JSON.stringify(mahasiswaData, null, 2));
    $('#jsonPreview').slideDown(200);
    $('#jsonToggleText').text('Sembunyikan');
    $('#jsonToggleIcon').attr('class', 'bi bi-eye-slash');
  } else {
    $('#jsonPreview').slideUp(200);
    $('#jsonToggleText').text('Tampilkan');
    $('#jsonToggleIcon').attr('class', 'bi bi-eye');
  }
}

function hapusMahasiswa(id, nama) {
  Swal.fire({
    title: 'Hapus Data?',
    html: `Data <strong>${nama}</strong> akan dihapus permanen!`,
    icon: 'warning',
    showCancelButton: true,
    confirmButtonColor: '#dc3545',
    cancelButtonColor: '#6c757d',
    confirmButtonText: '<i class="bi bi-trash3-fill me-1"></i> Ya, Hapus!',
    cancelButtonText: 'Batal'
  }).then((result) => {
    if (result.isConfirmed) {
      $.ajax({
        url: `/api/mahasiswa/${id}`,
        method: 'DELETE',
        success: (res) => {
          Swal.fire({ title: 'Terhapus!', text: res.message, icon: 'success', timer: 2000, showConfirmButton: false })
            .then(() => window.location.href = '/');
        },
        error: () => Swal.fire('Error!', 'Gagal menghapus data.', 'error')
      });
    }
  });
}
</script>

<%- include('footer') %>
