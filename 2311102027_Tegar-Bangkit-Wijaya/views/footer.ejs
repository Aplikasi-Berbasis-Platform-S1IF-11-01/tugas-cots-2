<!-- ── Confirm Delete Modal ── -->
<div class="modal fade" id="deleteModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0 shadow-lg">
      <div class="modal-header border-0 pb-0">
        <div class="delete-icon-wrap">
          <i class="bi bi-exclamation-triangle-fill text-danger"></i>
        </div>
      </div>
      <div class="modal-body text-center px-4 py-3">
        <h5 class="fw-700 mb-1">Hapus Data Mahasiswa?</h5>
        <p class="text-muted mb-0">Data <strong id="deleteNama"></strong> akan dihapus secara permanen dan tidak dapat dikembalikan.</p>
      </div>
      <div class="modal-footer border-0 justify-content-center gap-2 pb-4">
        <button class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">
          <i class="bi bi-x-lg me-1"></i> Batal
        </button>
        <button class="btn btn-danger px-4" id="confirmDelete">
          <i class="bi bi-trash3-fill me-1"></i> Ya, Hapus
        </button>
      </div>
    </div>
  </div>
</div>

